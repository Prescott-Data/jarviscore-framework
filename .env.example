# =============================================================================
# JARVISCORE FRAMEWORK CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# All settings are optional - framework provides sensible defaults
# Note: P2P bind settings use JARVISCORE_ prefix (see P2P section below)

# =============================================================================
# LLM CONFIGURATION (Zero-Config with Automatic Fallback)
# =============================================================================
# Framework tries providers in order: Azure OpenAI → Claude → vLLM → Gemini
# At least ONE provider must be configured for AutoAgent to work

# --- Azure OpenAI (Primary) ---
# Standard: AZURE_API_KEY or AZURE_OPENAI_KEY
# AZURE_API_KEY=your-azure-openai-key
# AZURE_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_DEPLOYMENT=gpt-4o
# AZURE_API_VERSION=2025-01-01-preview

# --- Model Routing (Azure deployment IDs for kernel subagents) ---
# CODING_MODEL=dromos-gpt-4.1   # Code generation (GPT-4.1)
# TASK_MODEL=gpt-4o              # Research, communication

# --- Anthropic Claude (Fallback #1) ---
# CLAUDE_API_KEY=your-anthropic-api-key
# CLAUDE_ENDPOINT=https://api.anthropic.com  # Optional: custom endpoint
# CLAUDE_MODEL=claude-sonnet-4

# --- vLLM (Local/Self-Hosted) ---
# Recommended for development and cost-effective production
# LLM_ENDPOINT=http://localhost:8000
# LLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# --- Google Gemini (Fallback #2) ---
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_TEMPERATURE=0.1
# GEMINI_TIMEOUT=30.0

# Common LLM Settings
# LLM_TIMEOUT=120.0
# LLM_TEMPERATURE=0.7

# =============================================================================
# EXECUTION SETTINGS
# =============================================================================
# Sandbox execution and code generation limits

# Maximum execution time for generated code (seconds)
EXECUTION_TIMEOUT=300

# Maximum number of autonomous repair attempts
MAX_REPAIR_ATTEMPTS=3

# Maximum retries for failed operations
MAX_RETRIES=3

# =============================================================================
# SANDBOX CONFIGURATION (Phase 2)
# =============================================================================
# Sandbox execution mode: "local" (in-process) or "remote" (service)
# Default: local (for development)
# Production: remote (uses JarvisCore's Azure Container Apps sandbox)
SANDBOX_MODE=local

# Remote sandbox service URL (provided by JarvisCore)
# Azure Container Apps sandbox service - no setup required!
# Uncomment and set SANDBOX_MODE=remote to use it
# SANDBOX_SERVICE_URL=https://browser-task-executor.bravesea-3f5f7e75.eastus.azurecontainerapps.io

# =============================================================================
# REDIS CONTEXT STORE (Phase 1, 4, 7, 8, 9)
# =============================================================================
# Enables: cross-step state, mailbox, episodic ledger, LTM, crash recovery
# Install: pip install "jarviscore-framework[redis]"
# REDIS_URL=redis://localhost:6379/0
# REDIS_CONTEXT_TTL_DAYS=7

# =============================================================================
# BLOB STORAGE (Phase 1, 8, 9)
# =============================================================================
# "local" (default, zero-setup) or "azure"
STORAGE_BACKEND=local
STORAGE_BASE_PATH=./blob_storage

# Azure Blob (production upgrade — leave blank for local dev)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_CONTAINER_NAME=jarviscore

# =============================================================================
# TELEMETRY / PROMETHEUS (Phase 5, 9)
# =============================================================================
# Install: pip install "jarviscore-framework[prometheus]"
# PROMETHEUS_ENABLED=true
# PROMETHEUS_PORT=9090

# =============================================================================
# NEXUS GATEWAY AUTH (Phase 7D — production mode)
# =============================================================================
# Required when auth_mode="production" (Example 3 — support swarm)
# Tests the full NexusClient flow: request_connection → check_status → resolve_strategy
# NEXUS_GATEWAY_URL=https://your-dromos-gateway.example.com

# =============================================================================
# STORAGE CONFIGURATION (Phase 1)
# =============================================================================
# Directory for result storage and code registry
LOG_DIRECTORY=./logs

# =============================================================================
# P2P CONFIGURATION (For Distributed Mode)
# =============================================================================
# Required only if using mesh in distributed mode
# Autonomous mode works without P2P

# Enable P2P mesh networking
P2P_ENABLED=true

# ---------------------------------------------------------------------------
# Per-process P2P settings — JARVISCORE_ prefix
#
# bind_port and bind_host are per-node settings. In a multi-node deployment
# each process needs a different port, so these cannot be set once in a
# shared .env file. Set them explicitly in the Mesh config dict instead:
#
#   mesh = Mesh(mode="distributed", config={"bind_port": 7949, ...})
#
# If you prefer env vars, set them per-process at launch time (not here):
#
#   JARVISCORE_BIND_PORT=7949 python ex2_synthesizer.py
#   JARVISCORE_BIND_PORT=7946 python ex2_research_node1.py
#
# The JARVISCORE_ prefix prevents collisions with variables read by the
# swim networking package during import.
# ---------------------------------------------------------------------------

# Node identification (shared default — override per-process if needed)
JARVISCORE_NODE_NAME=jarviscore-node

# Bind address — leave unset for default 127.0.0.1; override per-process
# JARVISCORE_BIND_HOST=127.0.0.1

# Bind port — leave unset for default 7946; always set per-process for multi-node
# JARVISCORE_BIND_PORT=7946

# Seed nodes — set per-process or leave empty for seed node itself
# JARVISCORE_SEED_NODES=127.0.0.1:7949

# ZeroMQ port offset (P2P messaging)
ZMQ_PORT_OFFSET=1000

# Transport type: udp, tcp, or hybrid
TRANSPORT_TYPE=hybrid

# =============================================================================
# KEEPALIVE SETTINGS (P2P Health Monitoring)
# =============================================================================

# Enable smart keepalive (suppresses when active)
KEEPALIVE_ENABLED=true

# Keepalive interval (seconds)
KEEPALIVE_INTERVAL=90

# Keepalive timeout (seconds)
KEEPALIVE_TIMEOUT=10

# Activity suppression window (seconds)
# If agent is actively working, suppress keepalive for this duration
ACTIVITY_SUPPRESS_WINDOW=60

# =============================================================================
# LOGGING
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# EXAMPLES
# =============================================================================

# Example 1: Local development with vLLM
# LLM_ENDPOINT=http://localhost:8000
# LLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
# P2P_ENABLED=false

# Example 2: Production with Azure OpenAI + P2P mesh
# AZURE_API_KEY=sk-...
# AZURE_ENDPOINT=https://my-resource.openai.azure.com
# AZURE_DEPLOYMENT=gpt-4o
# P2P_ENABLED=true
# Set per-process at launch: JARVISCORE_BIND_HOST=0.0.0.0 JARVISCORE_BIND_PORT=7946 python node.py
# JARVISCORE_SEED_NODES=192.168.1.100:7946

# Example 3: Zero-config (use defaults)
# Just don't set any variables and framework will:
# - Try to detect available LLM providers
# - Use sensible defaults for all settings
# - Work in autonomous mode (no P2P)
