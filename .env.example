# =============================================================================
# JARVISCORE FRAMEWORK CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# All settings are optional - framework provides sensible defaults
# Use JARVISCORE_ prefix for all environment variables

# =============================================================================
# LLM CONFIGURATION (Choose one or enable AUTO_FALLBACK)
# =============================================================================
# Framework tries providers in order: vLLM → Azure → Gemini → Claude
# At least ONE provider must be configured for AutoAgent to work

# --- vLLM (Local/Self-Hosted) ---
# Recommended for development and cost-effective production
JARVISCORE_LLM_ENDPOINT=http://localhost:8000
JARVISCORE_LLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# --- Azure OpenAI ---
# JARVISCORE_AZURE_API_KEY=your-azure-openai-key
# JARVISCORE_AZURE_ENDPOINT=https://your-resource.openai.azure.com
# JARVISCORE_AZURE_DEPLOYMENT=gpt-4o
# JARVISCORE_AZURE_API_VERSION=2024-02-15-preview

# --- Google Gemini ---
# JARVISCORE_GEMINI_API_KEY=your-gemini-api-key
# JARVISCORE_GEMINI_MODEL=gemini-1.5-flash

# --- Anthropic Claude ---
# JARVISCORE_CLAUDE_API_KEY=your-anthropic-api-key
# JARVISCORE_CLAUDE_ENDPOINT=https://api.anthropic.com  # Optional: custom endpoint
# JARVISCORE_CLAUDE_MODEL=claude-sonnet-4

# Common LLM Settings
# JARVISCORE_LLM_TIMEOUT=120
# JARVISCORE_LLM_TEMPERATURE=0.3

# =============================================================================
# EXECUTION SETTINGS
# =============================================================================
# Sandbox execution and code generation limits

# Maximum execution time for generated code (seconds)
JARVISCORE_EXECUTION_TIMEOUT=300

# Maximum number of autonomous repair attempts
JARVISCORE_MAX_REPAIR_ATTEMPTS=3

# Maximum retries for failed operations
JARVISCORE_MAX_RETRIES=3

# =============================================================================
# P2P CONFIGURATION (For Distributed Mode)
# =============================================================================
# Required only if using mesh in distributed mode
# Autonomous mode works without P2P

# Enable P2P mesh networking
JARVISCORE_P2P_ENABLED=true

# Node identification
JARVISCORE_NODE_NAME=jarviscore-node-1

# Bind address and port for P2P communication
JARVISCORE_BIND_HOST=127.0.0.1
JARVISCORE_BIND_PORT=7946

# Seed nodes to join existing mesh (comma-separated)
# Example: 192.168.1.100:7946,192.168.1.101:7946
# JARVISCORE_SEED_NODES=

# ZeroMQ port offset (P2P messaging)
JARVISCORE_ZMQ_PORT_OFFSET=1000

# Transport type: udp, tcp, or hybrid
JARVISCORE_TRANSPORT_TYPE=hybrid

# =============================================================================
# KEEPALIVE SETTINGS (P2P Health Monitoring)
# =============================================================================

# Enable smart keepalive (suppresses when active)
JARVISCORE_KEEPALIVE_ENABLED=true

# Keepalive interval (seconds)
JARVISCORE_KEEPALIVE_INTERVAL=90

# Keepalive timeout (seconds)
JARVISCORE_KEEPALIVE_TIMEOUT=10

# Activity suppression window (seconds)
# If agent is actively working, suppress keepalive for this duration
JARVISCORE_ACTIVITY_SUPPRESS_WINDOW=60

# =============================================================================
# LOGGING
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
JARVISCORE_LOG_LEVEL=INFO

# =============================================================================
# EXAMPLES
# =============================================================================

# Example 1: Local development with vLLM
# JARVISCORE_LLM_ENDPOINT=http://localhost:8000
# JARVISCORE_LLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
# JARVISCORE_P2P_ENABLED=false

# Example 2: Production with Azure OpenAI + P2P mesh
# JARVISCORE_AZURE_API_KEY=sk-...
# JARVISCORE_AZURE_ENDPOINT=https://my-resource.openai.azure.com
# JARVISCORE_AZURE_DEPLOYMENT=gpt-4o
# JARVISCORE_P2P_ENABLED=true
# JARVISCORE_BIND_HOST=0.0.0.0
# JARVISCORE_BIND_PORT=7946
# JARVISCORE_SEED_NODES=192.168.1.100:7946

# Example 3: Zero-config (use defaults)
# Just don't set any variables and framework will:
# - Try to detect available LLM providers
# - Use sensible defaults for all settings
# - Work in autonomous mode (no P2P)

# =============================================================================
# ADVANCED SETTINGS (Usually don't need to change)
# =============================================================================

# State management (future features)
# JARVISCORE_REDIS_HOST=localhost
# JARVISCORE_REDIS_PORT=6379
# JARVISCORE_REDIS_DB=0

# Event streaming (future features)
# JARVISCORE_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# JARVISCORE_KAFKA_TASKS_TOPIC=jarviscore-tasks
# JARVISCORE_KAFKA_STATUS_TOPIC=jarviscore-status
